{
  "name": "road-trip-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Map-centric road-trip planner for south Anhui & north Zhejiang, anchored at home in Suzhou.",
  "scripts": {
    "dev": "concurrently -k -n vite,server -c cyan,magenta \"npm:dev:client\" \"npm:server\"",
    "dev:client": "vite",
    "server": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "migrate:seed": "tsx scripts/migrate-seed.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "express": "^4.22.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/express": "^4.17.25",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.3",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
