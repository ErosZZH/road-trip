# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
coverage/

# On-disk catalog data (the backend's source of truth). Keep the folder
# skeleton (.gitkeep) but ignore the per-entity JSON files; commit exports
# instead when you want to version a snapshot.
data/places/*.json
data/routes/*.json
data/trips/*.json

# TypeScript / Vite build artifacts
*.tsbuildinfo
vite.config.js
vite.config.d.ts

# Playwright MCP scratch output
.playwright-mcp/

# Local env files (keep your Baidu AK private)
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
*.local
*.log
.vscode/*
!.vscode/extensions.json
.idea/
